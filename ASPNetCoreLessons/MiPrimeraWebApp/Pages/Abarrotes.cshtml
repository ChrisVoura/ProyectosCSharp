@page
@model AbarrotesModel
@{
    ViewData["Title"] = "Abarrotes";
}

<h1>@ViewData["Title"]</h1>
<p>En esta sección encontrarás una variedad de productos de abarrotes para tu hogar</p>

@Html.ValidationSummary(false, "", new { @class = "text-danger" })

<div class="row g-2">
    @foreach (var producto in Model.Productos)
    {
        <div class="col-md-3">
            <div class="card h-100 product-card">
                <a asp-page="/Detalles" asp-route-id="@producto.Id">
                <div class="card-header product-image-container">
                    @{
                        var imageUrls = producto.ImageUrl?.Split(',').Select(url => url.Trim()).ToList() ?? new List<string>();
                    }
                    @if (imageUrls.Count > 0)
                    {
                        <img src="@imageUrls[0]" alt="@producto.Name" class="product-image">
                    }
                </div>
                </a>
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title product-name">@producto.Name</h5>
                    <p class="card-text truncate-description">@producto.Description</p>
                    <div class="mt-auto">
                        <p class="product-price"><strong>₡@producto.Price.ToString("F3")</strong></p>
                    </div>
                </div>
                <div class="card-footer border-top">
                    <form method="post" asp-page="/Carrito" asp-page-handler="Agregar" asp-route-id="@producto.Id"
                          style="display:inline; font-weight: bold;" onsubmit="actualizarIconoCarrito()">
                        <button type="submit" class="btn btn-primary w-100">+ Agregar</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>