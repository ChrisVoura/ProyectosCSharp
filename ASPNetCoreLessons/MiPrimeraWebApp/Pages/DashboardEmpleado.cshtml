@page
@model MiPrimeraWebApp.Pages.DashboardEmpleadoModel
@{
    ViewData["Title"] = "Dashboard Empleado";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Dashboard de Empleado</h1>
            <p class="text-muted mb-0">Resumen de tu actividad</p>
        </div>
        <div class="text-end">
            <small class="text-muted">@DateTime.Now.ToString("dddd, d 'de' MMMM 'de' yyyy")</small>
        </div>
    </div>
    
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 hover-lift" style="border-radius: 16px;">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-secondary bg-opacity-10 rounded-3 p-3 me-3" style="width: 56px; height: 56px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-box-seam-fill text-secondary" style="font-size: 1.5rem;"></i>
                    </div>
                    <div>
                        <small class="text-muted text-uppercase fw-medium d-block">Total Productos</small>
                        <h3 class="mb-0 fw-bold">@Model.TotalProductos</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 hover-lift" style="border-radius: 16px;">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-danger bg-opacity-10 rounded-3 p-3 me-3" style="width: 56px; height: 56px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 1.5rem;"></i>
                    </div>
                    <div>
                        <small class="text-muted text-uppercase fw-medium d-block">Stock Bajo</small>
                        <h3 class="mb-0 fw-bold text-danger">@Model.ProductosStockBajo</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 hover-lift" style="border-radius: 16px;">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3 me-3" style="width: 56px; height: 56px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-receipt text-success" style="font-size: 1.5rem;"></i>
                    </div>
                    <div>
                        <small class="text-muted text-uppercase fw-medium d-block">Pedidos Recientes</small>
                        <h3 class="mb-0 fw-bold text-success">@Model.PedidosRecientes</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 hover-lift" style="border-radius: 16px;">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3 me-3" style="width: 56px; height: 56px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-percent text-warning" style="font-size: 1.5rem;"></i>
                    </div>
                    <div>
                        <small class="text-muted text-uppercase fw-medium d-block">En Descuento</small>
                        <h3 class="mb-0 fw-bold text-warning">@Model.ProductosEnDescuento</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1 fw-bold">Productos con Stock Bajo</h5>
                            <small class="text-muted">Requieren atención inmediata</small>
                        </div>
                        <span class="badge bg-danger bg-opacity-10 text-danger fs-6">@Model.ProductosStockBajoLista.Count</span>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (Model.ProductosStockBajoLista.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="border-0 px-4 py-3">Producto</th>
                                        <th class="border-0 py-3">Precio</th>
                                        <th class="border-0 py-3">Stock</th>
                                        <th class="border-0 py-3">Categoría</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var producto in Model.ProductosStockBajoLista.Take(5))
                                    {
                                        <tr>
                                            <td class="px-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-danger bg-opacity-10 rounded-circle p-2 me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                        <small class="text-danger fw-bold">@(producto.Name?.Length > 0 ? producto.Name[0].ToString().ToUpper() : "?")</small>
                                                    </div>
                                                    <span class="fw-medium">@producto.Name</span>
                                                </div>
                                            </td>
                                            <td class="py-3">₡@producto.Price.ToString("F3")</td>
                                            <td class="py-3">
                                                <span class="badge bg-danger">@producto.Stock</span>
                                            </td>
                                            <td class="py-3"><small class="text-muted">@producto.Category</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if(Model.ProductosStockBajoLista.Count > 5)
                        {
                            <div class="text-center py-3 border-top">
                                <small class="text-muted">Mostrando 5 de @Model.ProductosStockBajoLista.Count productos</small>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-check-circle text-success" style="font-size: 3rem;"></i>
                            <p class="text-muted mb-0 mt-2">¡Excelente! No hay productos con stock bajo.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1 fw-bold">Pedidos Recientes</h5>
                            <small class="text-muted">Últimos 7 días</small>
                        </div>
                        <span class="badge bg-success bg-opacity-10 text-success fs-6">@Model.PedidosRecientesLista.Count</span>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (Model.PedidosRecientesLista.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="border-0 px-4 py-3">ID</th>
                                        <th class="border-0 py-3">Cliente</th>
                                        <th class="border-0 py-3">Fecha</th>
                                        <th class="border-0 py-3">Total</th>
                                        <th class="border-0 py-3">Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pedido in Model.PedidosRecientesLista.Take(5))
                                    {
                                        <tr>
                                            <td class="px-4 py-3">
                                                <span class="fw-medium text-primary">#@pedido.Id</span>
                                            </td>
                                            <td class="py-3">@pedido.Cliente?.Name</td>
                                            <td class="py-3"><small class="text-muted">@pedido.FechaPedido.ToString("dd/MM")</small></td>
                                            <td class="py-3 fw-bold">₡@pedido.Total.ToString("F3")</td>
                                            <td class="py-3">
                                                @switch (pedido.Estado)
                                                {
                                                    case "Pendiente":
                                                        <span class="badge bg-warning bg-opacity-10 text-warning">Pendiente</span>
                                                        break;
                                                    case "EnProceso":
                                                        <span class="badge bg-info bg-opacity-10 text-info">En Proceso</span>
                                                        break;
                                                    case "Completado":
                                                        <span class="badge bg-success bg-opacity-10 text-success">Completado</span>
                                                        break;
                                                    case "Cancelado":
                                                        <span class="badge bg-danger bg-opacity-10 text-danger">Cancelado</span>
                                                        break;
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if(Model.PedidosRecientesLista.Count > 5)
                        {
                            <div class="text-center py-3 border-top">
                                <small class="text-muted">Mostrando 5 de @Model.PedidosRecientesLista.Count pedidos</small>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mb-0 mt-2">No hay pedidos recientes.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-12">
            <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1 fw-bold">Productos en Descuento</h5>
                            <small class="text-muted">Productos con promociones activas</small>
                        </div>
                        <span class="badge bg-warning bg-opacity-10 text-warning fs-6">@Model.ProductosEnDescuentoLista.Count</span>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (Model.ProductosEnDescuentoLista.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="border-0 px-4 py-3">Producto</th>
                                        <th class="border-0 py-3">Precio Original</th>
                                        <th class="border-0 py-3">Precio con Descuento</th>
                                        <th class="border-0 py-3">Descuento</th>
                                        <th class="border-0 py-3">Categoría</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var producto in Model.ProductosEnDescuentoLista)
                                    {
                                        var porcentaje = producto.PorcentajeDescuento > 0 ? producto.PorcentajeDescuento : 50;
                                        var precioDescuento = producto.Price * (1 - porcentaje / 100m);
                                        <tr>
                                            <td class="px-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-warning bg-opacity-10 rounded-circle p-2 me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                        <small class="text-warning fw-bold">@(producto.Name?.Length > 0 ? producto.Name[0].ToString().ToUpper() : "?")</small>
                                                    </div>
                                                    <span class="fw-medium">@producto.Name</span>
                                                </div>
                                            </td>
                                            <td class="py-3 text-muted text-decoration-line-through">₡@producto.Price.ToString("F3")</td>
                                            <td class="py-3 fw-bold text-success">₡@precioDescuento.ToString("F3")</td>
                                            <td class="py-3">
                                                <span class="badge bg-warning">-@porcentaje%</span>
                                            </td>
                                            <td class="py-3"><small class="text-muted">@producto.Category</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-tag text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mb-0 mt-2">No hay productos en descuento.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
