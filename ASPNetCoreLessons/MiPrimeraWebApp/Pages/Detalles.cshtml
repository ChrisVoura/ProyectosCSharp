@page
@model DetallesModel
@{
    ViewData["Title"] = "Detalles";
}

@if (Model.Producto == null)
{
    <div class="alert alert-warning">No se encontró el producto. Verifica el enlace.</div>
}
else
{
    var imageUrls = Model.Producto.ImageUrl?.Split(',').Select(url => url.Trim()).ToList() ?? new List<string>();
    
    @if (imageUrls.Count > 0)
    {
        <div id="detailCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
            <div class="carousel-inner">
                @for (int i = 0; i < imageUrls.Count; i++)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@imageUrls[i]" alt="@Model.Producto.Name" style="height: 400px; object-fit: contain; width: 100%; display: block; margin: 0 auto;">
                    </div>
                }
            </div>
            @if (imageUrls.Count > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#detailCarousel" data-bs-slide="prev" id ="carritoIcon">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#detailCarousel" data-bs-slide="next" id="carritoIcon">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                </button>
            }
        </div>
    }

    <div class="card mb-5">
        <div class="card-header">
            <h2>@Model.Producto.Name</h2>
        </div>
        <div class="card-body">
            <p><strong>Categoría:</strong> @Model.Producto.Category</p>
            <p><strong>Descripción:</strong> @Model.Producto.Description</p>
            <p><strong>Precio:</strong> ₡@Model.Producto.Price.ToString("F3")</p>
        </div>
        <div class="card-footer">
            <form method="post" asp-page="/Carrito" asp-page-handler="Agregar" asp-route-id="@Model.Producto.Id" style="display:inline;" onsubmit="actualizarIconoCarrito()">
                <button type="submit" class="btn btn-success">Agregar al Carrito</button>
            </form>
        </div>
    </div>
}