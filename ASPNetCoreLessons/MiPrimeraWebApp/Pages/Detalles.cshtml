@page
@model DetallesModel
@{
    ViewData["Title"] = "Detalles";
}

@if (Model.Producto == null)
{
    <div class="alert alert-warning">No se encontró el producto. Verifica el enlace.</div>
}
else
{
    var imageUrls = Model.Producto.ImageUrl?.Split(',').Select(url => url.Trim()).ToList() ?? new List<string>();
    
    <div class="d-flex flex-column align-items-center">
    @if (imageUrls.Count > 0)
    {
        <div id="detailCarousel" class="carousel slide mb-4" data-bs-ride="carousel" style="max-width: 500px;">
            <div class="carousel-inner">
                @for (int i = 0; i < imageUrls.Count; i++)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@imageUrls[i]" alt="@Model.Producto.Name" style="height: 300px; object-fit: contain; width: 100%; display: block; margin: 0 auto;">
                    </div>
                }
            </div>
            @if (imageUrls.Count > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#detailCarousel" data-bs-slide="prev" id ="carritoIcon">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#detailCarousel" data-bs-slide="next" id="carritoIcon">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                </button>
            }
        </div>
    }

    <div class="card mb-5" style="max-width: 700px; width: 100%;">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2>@Model.Producto.Name</h2>
            <button type="button" class="btn btn-link p-0" onclick="agregarALista(@Model.Producto.Id, event)" title="Agregar a mi lista">
                <img width="40" height="40" src="https://img.icons8.com/parakeet-line/48/hearts.png" alt="hearts"/>
            </button>
        </div>
        <div class="card-body">
            <p><strong>Categoría:</strong> @Model.Producto.Category</p>
            <p><strong>Descripción:</strong> @Model.Producto.Description</p>
            @if (Model.Producto.DescuentoActivo)
            {
                var descuento = Model.Producto.PorcentajeDescuento > 0 ? Model.Producto.PorcentajeDescuento : 50;
                var precioDescuento = Model.Producto.Price * (1 - descuento / 100m);
                <p class="text-muted text-decoration-line-through"><strong>Precio:</strong> ₡@Model.Producto.Price.ToString("F3")</p>
                <p class="text-danger"><strong>Precio:</strong> ₡@precioDescuento.ToString("F3") <span class="badge bg-danger">@descuento% OFF</span></p>
            }
            else
            {
                <p><strong>Precio:</strong> ₡@Model.Producto.Price.ToString("F3")</p>
            }
        </div>
        <div class="card-footer">
            <form method="post" asp-page="/Carrito" asp-page-handler="Agregar" asp-route-id="@Model.Producto.Id" style="display:inline;" onsubmit="actualizarIconoCarrito()">
                @if(Model.Producto.Stock > 0)
                {
                    <button type="submit" class="btn btn-success">Agregar al Carrito</button>
                }
                else
                {
                    <button type="submit" class="btn btn-secondary" disabled>Agotado</button>
                }
            </form>
        </div>
    </div>
    </div>
}