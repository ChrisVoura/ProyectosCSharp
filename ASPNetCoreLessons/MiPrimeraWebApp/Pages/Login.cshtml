@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="col-md-4">
        <h1 class="text-center mb-4">@ViewData["Title"]</h1>

        @if (ViewData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@ViewData["ErrorMessage"]</div>
        }

        @if (Model.ShowPassword)
        {
            <div class="alert alert-success" role="alert">
                Cuenta encontrada. Ingrese su contraseña.
            </div>
            <form method="post" asp-page-handler="Login">
                <input type="hidden" name="Email" value="@Model.EmailVal" />
                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input name="Password" class="form-control" type="password" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Iniciar Sesión</button>
            </form>
            <hr />
            <a href="/Login" class="btn btn-outline-secondary w-100">Volver</a>
        }
        else
        {
            <form method="post" asp-page-handler="Verificar">
                <i style="font-size: 15px;">¿No estás seguro de tener una cuenta? Ingresa tu correo y lo comprobaremos por ti.</i>
                <div class="mb-3">
                    <br />
                    <label class="form-label">Email</label>
                    <input name="Email" class="form-control" type="email" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Continuar</button>
            </form>
        }
    </div>
</div>
